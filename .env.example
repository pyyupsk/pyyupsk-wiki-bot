# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=
# Application client ID (used for slash command deployment)
DISCORD_CLIENT_ID=
# Optional: register commands to a single guild (instant) instead of globally
DISCORD_GUILD_ID=

# Path to the claude CLI binary (default: "claude" on PATH)
CLAUDE_BIN=claude
# Model alias passed to claude --model (haiku | sonnet | opus)
CLAUDE_MODEL=haiku
# Wiki directory — granted to claude via --add-dir (defaults to ~/Obsidian/pyyupsk/wiki)
WIKI_DIR=
