{
  "name": "discord-bot",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "biome check --write .",
    "deploy": "bun run src/scripts/deploy.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.26.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
