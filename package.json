{
  "name": "discord-bot",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "biome check --write .",
    "deploy": "bun run src/scripts/deploy.ts",
    "dev": "bun --watch src/index.ts",
    "prepare": "nit install",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "discord.js": "^14.26.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@pyyupsk/nit": "^0.3.0",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "nit": {
    "hooks": {
      "pre-commit": {
        "stages": {
          "**/*.{ts,json}": "biome check --write --no-errors-on-unmatched {staged_files}"
        }
      },
      "pre-push": "bun run typecheck",
      "commit-msg": "bunx commitlint --edit $1"
    }
  }
}
